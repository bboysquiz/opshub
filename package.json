{
  "name": "opshub",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:frontend": "vitest run --coverage",
    "ports:free": "kill-port 3000 3001 3010 3020 3030",
    "docker:up:db": "docker compose up -d db",
    "docker:wait:db": "sh -c 'until docker compose exec -T db pg_isready -U opshub -d opshub; do sleep 1; done'",
    "docker:up:full": "docker compose up -d",
    "docker:down": "docker compose down",
    "dev:core": "pnpm run ports:free && pnpm -r --parallel --filter server --filter host-nuxt --filter tickets-remote --filter kb-remote --filter analytics-remote dev",
    "dev:start": "pnpm docker:up:db && pnpm docker:wait:db && pnpm --filter server migrate && pnpm dev:core",
    "lint": "eslint .",
    "format": "prettier -w .",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": "10.30.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opshub/shared-config": "workspace:*",
    "@opshub/shared-ui": "workspace:*",
    "@quasar/extras": "^1.17.0",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/compiler-sfc": "^3.5.30",
    "@vue/test-utils": "^2.4.6",
    "chart.js": "^4.5.1",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "kill-port": "^2.0.1",
    "lint-staged": "^16.2.7",
    "pinia": "^3.0.4",
    "prettier": "^3.8.1",
    "quasar": "^2.18.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.3",
    "vue-eslint-parser": "^10.4.0"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,js,vue}": [
      "eslint --fix",
      "prettier -w"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier -w"
    ]
  }
}
